.pio
.vscode/.browse.c_cpp.db*
.vscode/c_cpp_properties.json
.vscode/launch.json
.vscode/ipch

# Python tool venvs + bytecode (lobsterboy-side services).
__pycache__/
*.pyc
tools/*/.venv/
tools/*/*.egg-info/

# Local-only reference docs (mirrored from docs.m5stack.com + Axera).
# 32 MB of PDFs/markdown — see docs/reference/README.md for what's there.
docs/

# Local-only: per-user Claude Code settings, agents, hooks.
.claude/

# Android platform-tools (downloaded for adb access to the AX630C — not part
# of the firmware build).
platform-tools/
platform-tools-*.zip

# Not an npm project — guard against tools accidentally seeding node tooling
# at the repo root.
node_modules/
package.json
package-lock.json
